###############################################################################
# Environment Configuration
###############################################################################

# ---- PostgreSQL ----
POSTGRES_DB=zabbix
POSTGRES_USER=zabbix
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_PORT=5432

# ---- Zabbix Server ----
DB_SERVER_HOST=postgres
ZBX_SERVER_HOST=zabbix-server
ZBX_SERVER_PORT=10051
ZBX_STARTPOLLERS=10
ZBX_STARTHTTPPOLLERS=5
ZBX_STARTPINGERS=5
ZBX_CACHESIZE=128M
ZBX_HISTORYCACHESIZE=64M
ZBX_TIMEOUT=30

# ---- Zabbix Web ----
ZBX_WEB_PORT=8080
ZBX_WEB_SSL_PORT=8443
PHP_TZ=Asia/Ho_Chi_Minh
ZABBIX_API_USER=Admin
ZABBIX_API_PASSWORD=zabbix

# ---- Tenant Discovery ----
# Endpoint returns the list of tenants to monitor
TENANT_API_URL=https://endpoint.cloud/get-available-tenant
TENANT_API_KEY=your_api_key_if_needed
DISCOVERY_INTERVAL=3600
# Probe <site>/HEALTHCHECK_REL_PATH before sync; HEALTHCHECK_FALLBACK_HTTP_STATUS => monitor site root
HEALTHCHECK_PROBE_TIMEOUT=10
HEALTHCHECK_REL_PATH=/webhooks/healthcheck.php
# Zabbix web scenario + HTTP item use POST JSON {"password": ...} when URL is this path (defaults to TENANT_API_KEY)
HEALTHCHECK_API_KEY=your_healthcheck_api_key
# Probe uses GET without auth body; 404 => monitor site root; 401/403 => health route exists
HEALTHCHECK_PROBE_USER_AGENT=tenant-discovery/1.0
HEALTHCHECK_PROBE_ACCEPT=*/*
HEALTHCHECK_FALLBACK_HTTP_STATUS=404

# Zabbix tenant HTTP checks (single upstream call per cycle via master/dependent items)
ZABBIX_API_URL=http://zabbix-web:8080/api_jsonrpc.php
ZABBIX_WEB_CHECK_DELAY=120s
ZABBIX_WEB_CHECK_TIMEOUT=7s
ZABBIX_WEB_CHECK_FOLLOW_REDIRECTS=1
ZABBIX_TRIGGER_DOWN_RSP_CODES=500,502,503,504
# Master item (HTTP agent) — hits the tenant URL once per cycle; dependent
# items derive status code and response body via preprocessing.
ZABBIX_HEALTH_MASTER_ITEM_KEY=healthcheck.raw
ZABBIX_HEALTH_MASTER_ITEM_NAME=Healthcheck raw (master)
ZABBIX_HEALTH_STATUSCODE_ITEM_KEY=healthcheck.statuscode
ZABBIX_HEALTH_STATUSCODE_ITEM_NAME=Healthcheck HTTP status code
ZABBIX_HEALTH_RESPONSE_ITEM_KEY=healthcheck.response.raw
ZABBIX_HEALTH_RESPONSE_ITEM_NAME=Healthcheck response body
ZABBIX_HEALTH_RESPONSE_ITEM_DELAY=120s

LOG_LEVEL=INFO
